# REACTOR ($CORE) — production env (set in Vercel → Settings → Environment Variables)

# $CORE token contract (required for live mode)
VITE_CORE_CA=0x0000000000000000000000000000000000000000

# Reactor hook — claim + chargeScore reads (required for claim button)
VITE_REACTOR_HOOK_CA=0x0000000000000000000000000000000000000000

# 1 = Ethereum mainnet · 11155111 = Sepolia testnet
VITE_CHAIN_ID=1

# Optional: dedicated RPC (Alchemy, Infura, etc.)
# VITE_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: WalletConnect for mobile wallets — https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=
