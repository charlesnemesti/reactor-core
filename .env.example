# REACTOR ($REACTOR) — production env (set in Vercel → Settings → Environment Variables)

# $REACTOR token + hook (optional — defaults to mainnet address in src/config/env.ts)
VITE_CORE_CA=0xA86986Fb2396f9826FF03BAF67B21FCf2F7b20cC

# Same contract if omitted
# VITE_REACTOR_HOOK_CA=0xA86986Fb2396f9826FF03BAF67B21FCf2F7b20cC

# 1 = Ethereum mainnet · 11155111 = Sepolia testnet
VITE_CHAIN_ID=1

# Strongly recommended for production — public RPCs limit eth_getLogs range (~100 blocks)
# VITE_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: WalletConnect for mobile wallets — https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=
